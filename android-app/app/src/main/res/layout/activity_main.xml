<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Islamic Header with mosque silhouette -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/header_gradient">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:src="@drawable/mosque_silhouette"
                android:scaleType="centerInside"
                android:layout_gravity="center"
                android:importantForAccessibility="no" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="32dp"
                android:paddingBottom="24dp">

                <!-- Bismillah -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="﷽"
                    android:textSize="28sp"
                    android:textColor="#D4AF37"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textAlignment="center" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/subtitle"
                    android:textSize="14sp"
                    android:textColor="#B2DFDB"
                    android:textAlignment="center"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/source"
                    android:textSize="11sp"
                    android:textColor="#80B2DFDB"
                    android:textAlignment="center"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- Geometric border strip -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:src="@drawable/islamic_border"
            android:scaleType="fitXY"
            android:importantForAccessibility="no" />

        <!-- Content area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/status_normal"
                        android:textSize="17sp"
                        android:textAlignment="center"
                        android:padding="16dp"
                        android:textColor="@color/text_dark" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Permission Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPermissionBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF3E0"
                app:strokeColor="#FFB74D"
                app:strokeWidth="1dp"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="20sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvPermissionMessage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="#E65100"
                        android:lineSpacingExtra="3dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Auto-Silence Toggle -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/auto_silence"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAutoSilence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Ramadan indicator -->
            <TextView
                android:id="@+id/tvRamadanIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ramadan_active"
                android:textSize="14sp"
                android:textColor="#D4AF37"
                android:textStyle="bold"
                android:textAlignment="center"
                android:background="#FFF8E1"
                android:padding="12dp"
                android:visibility="gone"
                android:layout_marginTop="12dp" />

            <!-- Location Picker Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/location_title"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/prayer_name"
                        android:drawableStart="@android:drawable/ic_menu_mylocation"
                        android:drawablePadding="8dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/label_delegation"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginBottom="4dp" />

                    <AutoCompleteTextView
                        android:id="@+id/actvDelegation"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_islamic"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:hint="@string/hint_search_delegation"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:completionThreshold="1"
                        android:singleLine="true"
                        android:importantForAutofill="no" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Prayer Times Settings Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPrayers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_settings_title"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/prayer_name"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_settings_subtitle"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"
                        android:layout_marginBottom="12dp" />

                    <!-- Column headers -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layoutDirection="rtl"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="@string/col_prayer"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="@string/col_time"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:textStyle="bold"
                            android:textAlignment="center" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="@string/col_duration"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:textStyle="bold"
                            android:textAlignment="center" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />

                    <!-- Prayer rows container -->
                    <LinearLayout
                        android:id="@+id/prayerRowsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Manual Toggle Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleSilence"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_silence"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@color/green_primary"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_lock_silent_mode"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                android:layout_marginTop="16dp" />

            <!-- Geometric border strip -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:src="@drawable/islamic_border"
                android:scaleType="fitXY"
                android:layout_marginTop="16dp"
                android:importantForAccessibility="no" />

            <!-- Info text -->
            <TextView
                android:id="@+id/tvInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/info_text"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:textAlignment="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
