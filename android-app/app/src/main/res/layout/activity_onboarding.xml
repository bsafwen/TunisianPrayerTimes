<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@anim/slide_in_left"
        android:outAnimation="@anim/slide_out_right">

        <!-- Step 1: Welcome -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="﷽"
                android:textSize="28sp"
                android:textColor="@color/green_primary_dark"
                android:layout_marginBottom="24dp" />

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/mosque_silhouette"
                android:layout_marginBottom="32dp"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary_dark"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_welcome"
                android:textSize="17sp"
                android:textColor="@color/text_dark"
                android:textAlignment="center"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

        <!-- Step 2: Duration mode (default) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_step2_title"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary_dark"
                android:textAlignment="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Demo prayer row card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginBottom="24dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layoutDirection="rtl"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.5"
                        android:text="@string/prayer_fajr"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/prayer_name" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="05:15"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:textAlignment="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.5"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="36dp"
                            android:text="60"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:textAlignment="center"
                            android:gravity="center"
                            android:background="@drawable/input_islamic"
                            android:padding="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/label_duration"
                            android:textSize="12sp"
                            android:textColor="@color/gold"
                            android:textStyle="bold"
                            android:padding="4dp" />
                    </LinearLayout>
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_step2_desc"
                android:textSize="16sp"
                android:textColor="@color/text_dark"
                android:textAlignment="center"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>

        <!-- Step 3: Tap "د" to switch to fixed time (animated demo) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_step3_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary_dark"
                android:layout_marginBottom="24dp" />

            <!-- Animated demo card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginBottom="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Before state: duration mode "60 د" -->
                    <LinearLayout
                        android:id="@+id/rowBefore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layoutDirection="rtl"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="@string/prayer_fajr"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/prayer_name" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="05:15"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:textAlignment="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="36dp"
                                android:text="60"
                                android:textSize="14sp"
                                android:textColor="@color/text_dark"
                                android:textAlignment="center"
                                android:gravity="center"
                                android:background="@drawable/input_islamic"
                                android:padding="4dp" />

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:clipChildren="false"
                                android:clipToPadding="false">

                                <View
                                    android:id="@+id/tapRipple"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_gravity="center"
                                    android:alpha="0"
                                    android:visibility="invisible" />

                                <TextView
                                    android:id="@+id/demoLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="@string/label_duration"
                                    android:textSize="14sp"
                                    android:textColor="@color/gold"
                                    android:textStyle="bold"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:minWidth="36dp"
                                    android:gravity="center" />
                            </FrameLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- After state: fixed time mode "06:15 حتى" -->
                    <LinearLayout
                        android:id="@+id/rowAfter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layoutDirection="rtl"
                        android:gravity="center_vertical"
                        android:alpha="0"
                        android:visibility="invisible">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:text="@string/prayer_fajr"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/prayer_name" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="05:15"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:textAlignment="center" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.5"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <TextView
                                android:layout_width="64dp"
                                android:layout_height="36dp"
                                android:text="06:15"
                                android:textSize="14sp"
                                android:textColor="@color/green_primary"
                                android:textAlignment="center"
                                android:gravity="center"
                                android:background="@drawable/input_islamic"
                                android:textStyle="bold"
                                android:padding="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/label_fixed_time"
                                android:textSize="12sp"
                                android:textColor="@color/green_primary"
                                android:textStyle="bold"
                                android:padding="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>



            <TextView
                android:id="@+id/step3Desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="3"
                android:text="@string/onboarding_step3_desc"
                android:textSize="16sp"
                android:textColor="@color/text_dark"
                android:textAlignment="center"
                android:lineSpacingExtra="6dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Step 4: Permissions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_perm_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary_dark"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_perm_desc"
                android:textSize="15sp"
                android:textColor="@color/text_dark"
                android:textAlignment="center"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="32dp" />

            <!-- DND permission row -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_perm_dnd"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/green_primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_perm_dnd_desc"
                            android:textSize="13sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantDnd"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/onboarding_perm_grant"
                        android:textSize="13sp"
                        android:backgroundTint="@color/green_primary"
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        app:cornerRadius="20dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Exact Alarm permission row -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/gold_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_perm_alarm"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/green_primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboarding_perm_alarm_desc"
                            android:textSize="13sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantAlarm"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="@string/onboarding_perm_grant"
                        android:textSize="13sp"
                        android:backgroundTint="@color/green_primary"
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        app:cornerRadius="20dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <!-- Step 5: Get started -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_ready_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/green_primary_dark"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_ready_desc"
                android:textSize="16sp"
                android:textColor="@color/text_dark"
                android:textAlignment="center"
                android:lineSpacingExtra="6dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>

    </ViewFlipper>

    <!-- Navigation buttons -->
    <LinearLayout
        android:id="@+id/navButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:layout_marginHorizontal="32dp"
        android:orientation="horizontal"
        android:layoutDirection="ltr"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrev"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/onboarding_prev"
            android:textSize="16sp"
            android:paddingHorizontal="24dp"
            android:visibility="gone"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:cornerRadius="28dp"
            app:strokeColor="@color/green_primary"
            android:textColor="@color/green_primary"
            android:layout_marginEnd="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/onboarding_start"
            android:textSize="18sp"
            android:paddingHorizontal="48dp"
            android:visibility="gone"
            android:backgroundTint="@color/green_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cornerRadius="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/onboarding_next"
            android:textSize="18sp"
            android:paddingHorizontal="48dp"
            android:backgroundTint="@color/green_primary"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cornerRadius="28dp" />

    </LinearLayout>

    <!-- Progress dots -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal" />

    <!-- Progress bar (video-like) -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:layout_marginTop="36dp"
        android:layout_marginHorizontal="24dp"
        android:orientation="horizontal">

        <View
            android:id="@+id/progressBar1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:background="@color/gold_light" />

        <View
            android:id="@+id/progressBar2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:background="@color/gold_light" />

        <View
            android:id="@+id/progressBar3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:background="@color/gold_light" />

        <View
            android:id="@+id/progressBar4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:background="@color/gold_light" />

        <View
            android:id="@+id/progressBar5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:background="@color/gold_light" />

    </LinearLayout>

</FrameLayout>
