<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layoutDirection="rtl"
    android:gravity="center_vertical"
    android:paddingVertical="10dp">

    <!-- Prayer name -->
    <TextView
        android:id="@+id/tvPrayerName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/prayer_name" />

    <!-- Prayer time -->
    <TextView
        android:id="@+id/tvPrayerTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.5"
        android:textSize="14sp"
        android:textColor="@color/text_dark"
        android:textAlignment="center" />

    <!-- Delay control -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:orientation="horizontal"
        android:gravity="center_vertical|center_horizontal">

        <!-- Delay minutes input (visible in MINUTES mode) -->
        <EditText
            android:id="@+id/etDelay"
            android:layout_width="42dp"
            android:layout_height="36dp"
            android:inputType="number"
            android:textSize="14sp"
            android:textColor="@color/text_dark"
            android:textAlignment="center"
            android:gravity="center"
            android:background="@drawable/input_islamic"
            android:padding="4dp"
            android:maxLength="3"
            android:importantForAutofill="no" />

        <!-- Delay fixed time display (visible in FIXED_TIME mode) -->
        <TextView
            android:id="@+id/tvDelayFixedTime"
            android:layout_width="52dp"
            android:layout_height="36dp"
            android:textSize="13sp"
            android:textColor="@color/text_dark"
            android:textAlignment="center"
            android:gravity="center"
            android:background="@drawable/input_islamic"
            android:padding="4dp"
            android:visibility="gone" />

        <!-- Delay mode label (tappable to toggle) -->
        <TextView
            android:id="@+id/tvDelayLabel"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="2dp"
            android:text="@string/label_delay_minutes"
            android:textSize="13sp"
            android:textColor="#D4AF37"
            android:gravity="center"
            android:padding="2dp" />

    </LinearLayout>

    <!-- Silence end control -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.2"
        android:orientation="horizontal"
        android:gravity="center_vertical|center_horizontal">

        <!-- Duration input (visible in DURATION mode) -->
        <EditText
            android:id="@+id/etAfter"
            android:layout_width="42dp"
            android:layout_height="36dp"
            android:inputType="number"
            android:textSize="14sp"
            android:textColor="@color/text_dark"
            android:textAlignment="center"
            android:gravity="center"
            android:background="@drawable/input_islamic"
            android:padding="4dp"
            android:maxLength="3"
            android:importantForAutofill="no" />

        <!-- Fixed time display (visible in FIXED_TIME mode) -->
        <TextView
            android:id="@+id/tvFixedTime"
            android:layout_width="52dp"
            android:layout_height="36dp"
            android:textSize="13sp"
            android:textColor="@color/text_dark"
            android:textAlignment="center"
            android:gravity="center"
            android:background="@drawable/input_islamic"
            android:padding="4dp"
            android:visibility="gone" />

        <!-- Mode label next to input (tappable to toggle) -->
        <TextView
            android:id="@+id/tvAfterLabel"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="2dp"
            android:text="@string/label_duration"
            android:textSize="13sp"
            android:textColor="#D4AF37"
            android:gravity="center"
            android:padding="2dp" />

    </LinearLayout>

</LinearLayout>
