<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to modify Do Not Disturb settings -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <!-- Required for exact alarms on Android 12+ (user must grant via Settings on Android 14+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Re-schedule alarms after reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.TunisianPrayerTimes">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Internal receiver for silence/unsilence/reschedule alarms -->
        <receiver
            android:name=".SilenceReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.tunisianprayertimes.ACTION_SILENCE" />
                <action android:name="com.tunisianprayertimes.ACTION_UNSILENCE" />
                <action android:name="com.tunisianprayertimes.ACTION_RESCHEDULE" />
            </intent-filter>
        </receiver>

        <!-- System broadcast receiver for boot/update (must be exported) -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
